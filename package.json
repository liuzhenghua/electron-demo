{
  "name": "electron-demo",
  "version": "1.0.0",
  "description": "A minimal and secure Electron desktop application",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently --kill-others --success first \"vite\" \"electron .\"",
    "server": "npm --prefix server start",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "vite": "^8.1.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "build": {
    "appId": "com.example.electrondemo",
    "productName": "Electron Demo",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities"
    }
  }
}
